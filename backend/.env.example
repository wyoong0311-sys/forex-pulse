APP_NAME=Forex Pulse API
APP_ENV=development
LOG_LEVEL=INFO
LOG_FORMAT=json
DATABASE_URL=sqlite:///./forex_pulse.db
# For PostgreSQL or Supabase use:
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/postgres?sslmode=require
FOREX_PROVIDER_URL=https://api.frankfurter.dev/v1
FOREX_API_KEY=
PROVIDER_TIMEOUT_SECONDS=12
PROVIDER_RETRY_ATTEMPTS=3
LATEST_RATES_CACHE_TTL_SECONDS=900
LATEST_RATES_CACHE_STALE_TTL_SECONDS=3600
HISTORY_RATES_CACHE_TTL_SECONDS=21600
HISTORY_RATES_CACHE_STALE_TTL_SECONDS=43200
DASHBOARD_CACHE_TTL_SECONDS=300
DASHBOARD_CACHE_STALE_TTL_SECONDS=900
STALE_DATA_MINUTES=120
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json
EXPO_PUSH_API_URL=https://exp.host/--/api/v2/push/send
EXPO_PUSH_ACCESS_TOKEN=
MOCK_DATA_ENABLED=true
NOTIFICATION_MOCK_ENABLED=true
NOTIFICATION_RETRY_ATTEMPTS=2
FEATURE_MACRO_CALENDAR_ENABLED=false
FEATURE_NEWS_SENTIMENT_ENABLED=false

# Production safety checklist:
# APP_ENV=production
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/postgres?sslmode=require
# MOCK_DATA_ENABLED=false
# NOTIFICATION_MOCK_ENABLED=true
# When ready for real push notifications:
# NOTIFICATION_MOCK_ENABLED=false
# FIREBASE_CREDENTIALS_PATH=/run/secrets/firebase-service-account.json
