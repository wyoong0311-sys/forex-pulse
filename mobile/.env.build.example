EXPO_PUBLIC_API_BASE_URL=https://your-forex-pulse-api.example.com
EXPO_PUBLIC_APP_NAME=Forex Pulse
EXPO_PUBLIC_APP_SLUG=forex-pulse
EXPO_PUBLIC_APP_VERSION=1.0.0
EXPO_PUBLIC_EXPO_OWNER=teows-organization
EXPO_PUBLIC_ANDROID_PACKAGE=com.forexpulse.mobile
EXPO_PUBLIC_ANDROID_VERSION_CODE=1
EXPO_PUBLIC_IOS_BUNDLE_ID=com.forexpulse.mobile
EXPO_PUBLIC_IOS_BUILD_NUMBER=1
EXPO_PUBLIC_EAS_PROJECT_ID=your-eas-project-id
GOOGLE_SERVICES_JSON=./google-services.json

# Notes:
# 1. EXPO_PUBLIC_API_BASE_URL must be reachable from a real phone.
# 2. GOOGLE_SERVICES_JSON should point to the Firebase Android config file in this folder.
# 3. EXPO_PUBLIC_EAS_PROJECT_ID comes from `npx eas project:init` or your Expo dashboard.
